DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# Where to read knowledge files (txt/md) from
RAG_DOCS_DIR=docs

# Where to persist Chroma DB
RAG_CHROMA_DIR=chroma_db

# Embedding provider: fastembed（默认，Cloud 轻量）| hf（需 pip sentence-transformers torch）| deepseek
RAG_EMBEDDING_PROVIDER=fastembed

# Embedding model:
# - fastembed: intfloat/multilingual-e5-small（中英等多语）
# - hf: BAAI/bge-small-zh-v1.5
# - deepseek: 以官方文档为准
RAG_EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Cloud 排查：若页面出现奇怪错误，可设为 1 关闭流式输出（一次返回整段）
# RAG_DISABLE_STREAMING=1

