DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# Where to read knowledge files (txt/md) from
RAG_DOCS_DIR=docs

# Where to persist Chroma DB
RAG_CHROMA_DIR=chroma_db

# Embedding provider: deepseek | hf
RAG_EMBEDDING_PROVIDER=deepseek

# Embedding model:
# - hf: BAAI/bge-small-zh-v1.5
# - deepseek: deepseek-embedding (or your DeepSeek embedding model name)
RAG_EMBEDDING_MODEL=deepseek-embedding

# Cloud 排查：若页面出现奇怪错误，可设为 1 关闭流式输出（一次返回整段）
# RAG_DISABLE_STREAMING=1

